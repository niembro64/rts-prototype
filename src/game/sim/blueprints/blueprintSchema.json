{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "budget-annihilation-blueprint-schema",
  "title": "Budget Annihilation Blueprint Schema",
  "description": "Canonical schema for blueprint and shot TypeScript/Rust type generation.",
  "$defs": {
    "UnitBlueprintId": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./blueprintIds", "name": "UnitBlueprintId" },
        "rustType": "String"
      }
    },
    "TurretBlueprintId": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./blueprintIds", "name": "TurretBlueprintId" },
        "rustType": "String"
      }
    },
    "LocomotionBlueprintId": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./blueprintIds", "name": "LocomotionBlueprintId" },
        "rustType": "String"
      }
    },
    "ShotBlueprintId": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./blueprintIds", "name": "ShotBlueprintId" },
        "rustType": "String"
      }
    },
    "ForceFieldMaterialId": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./blueprintIds", "name": "ForceFieldMaterialId" },
        "rustType": "String"
      }
    },
    "SoundEntry": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./audio", "name": "SoundEntry" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "BarrelShape": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./config", "name": "BarrelShape" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "TurretRangeOverrides": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./combatTypes", "name": "TurretRangeOverrides" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "ConstructionEmitterSize": {
      "type": "string",
      "x-codegen": {
        "tsImport": { "module": "./constructionTypes", "name": "ConstructionEmitterSize" },
        "rustType": "String"
      }
    },
    "ConstructionEmitterVisualSpec": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./constructionTypes", "name": "ConstructionEmitterVisualSpec" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "ResourceCost": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./economyTypes", "name": "ResourceCost" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "UnitSuspensionConfig": {
      "type": "object",
      "x-codegen": {
        "tsImport": { "module": "./locomotionTypes", "name": "UnitSuspensionConfig" },
        "rustType": "BlueprintJsonValue"
      }
    },
    "EntityId": {
      "type": "integer",
      "x-codegen": {
        "tsImport": { "module": "./entityTypes", "name": "EntityId" },
        "rustType": "i32"
      }
    },
    "PlayerId": {
      "type": "integer",
      "x-codegen": {
        "tsImport": { "module": "./entityTypes", "name": "PlayerId" },
        "rustType": "i32"
      }
    },

    "ProjectileShotKind": {
      "enum": ["plasma", "rocket"]
    },
    "LineShotType": {
      "enum": ["beam", "laser"]
    },
    "ForceFieldSurfaceResponse": {
      "enum": ["reflect", "absorb", "passThrough"]
    },
    "ForceFieldReflectionMode": {
      "enum": ["outside-in", "inside-out", "both"]
    },
    "ForceFieldBarrierRatioConfig": {
      "type": "object",
      "properties": {
        "outerRatio": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "rimWidth": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "originOffsetRadiusRatio": { "oneOf": [{ "type": "number" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialVisualConfig": {
      "type": "object",
      "required": ["color", "alpha", "particleAlpha"],
      "properties": {
        "color": { "type": "number" },
        "alpha": { "type": "number" },
        "particleAlpha": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialReflectionConfig": {
      "type": "object",
      "required": ["mode", "reflectivity"],
      "properties": {
        "mode": { "$ref": "#/$defs/ForceFieldReflectionMode" },
        "reflectivity": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialOcclusionConfig": {
      "type": "object",
      "required": ["blocksLineOfSight"],
      "properties": {
        "blocksLineOfSight": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialProjectileResponseConfig": {
      "type": "object",
      "required": ["plasma", "rocket", "beam", "laser"],
      "properties": {
        "plasma": { "$ref": "#/$defs/ForceFieldSurfaceResponse" },
        "rocket": { "$ref": "#/$defs/ForceFieldSurfaceResponse" },
        "beam": { "$ref": "#/$defs/ForceFieldSurfaceResponse" },
        "laser": { "$ref": "#/$defs/ForceFieldSurfaceResponse" }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialHitReactionConfig": {
      "type": "object",
      "required": ["impactEvent", "sound"],
      "properties": {
        "impactEvent": { "const": "forceFieldImpact" },
        "sound": { "oneOf": [{ "$ref": "#/$defs/SoundEntry" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "ForceFieldMaterialBlueprint": {
      "type": "object",
      "required": ["materialId", "reflection", "occlusion", "projectileResponse", "hitReaction", "visual"],
      "properties": {
        "materialId": { "$ref": "#/$defs/ForceFieldMaterialId" },
        "reflection": { "$ref": "#/$defs/ForceFieldMaterialReflectionConfig" },
        "occlusion": { "$ref": "#/$defs/ForceFieldMaterialOcclusionConfig" },
        "projectileResponse": { "$ref": "#/$defs/ForceFieldMaterialProjectileResponseConfig" },
        "hitReaction": { "$ref": "#/$defs/ForceFieldMaterialHitReactionConfig" },
        "visual": { "$ref": "#/$defs/ForceFieldMaterialVisualConfig" }
      },
      "additionalProperties": false
    },
    "ShotCollision": {
      "type": "object",
      "required": ["radius"],
      "properties": {
        "radius": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ShotExplosion": {
      "type": "object",
      "required": ["radius", "damage", "force"],
      "properties": {
        "radius": { "type": "number" },
        "damage": { "type": "number" },
        "force": { "type": "number" }
      },
      "additionalProperties": false
    },
    "SubmunitionSpec": {
      "type": "object",
      "required": ["shotBlueprintId", "count", "randomSpreadSpeedHorizontal", "randomSpreadSpeedVertical"],
      "properties": {
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "count": { "type": "integer" },
        "randomSpreadSpeedHorizontal": { "type": "number" },
        "randomSpreadSpeedVertical": { "type": "number" },
        "reflectedVelocityDamper": { "type": "number" }
      },
      "additionalProperties": false
    },
    "SmokeTrailSpec": {
      "type": "object",
      "required": ["capPolicy"],
      "properties": {
        "useId": { "type": "string" },
        "maxPoolSize": { "type": "number" },
        "capPolicy": { "enum": ["evictOldest", "skipWhenFull"] },
        "emitFramesSkip": { "type": "number" },
        "exhaustSpeed": { "type": "number" },
        "startRadius": { "type": "number" },
        "endRadiusMultiplier": { "type": "number" },
        "fadeInMs": { "type": "number" },
        "fadeOutMs": { "type": "number" },
        "maxAlpha": { "type": "number" },
        "color": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ProjectileShotBlueprint": {
      "type": "object",
      "required": [
        "type",
        "shotBlueprintId",
        "base",
        "mass",
        "health",
        "radius",
        "explosion",
        "detonateOnExpiry",
        "hitSound",
        "submunitions",
        "homingTurnRate",
        "homingThrust",
        "gravityForceMultiplier",
        "smokeTrail"
      ],
      "properties": {
        "type": { "$ref": "#/$defs/ProjectileShotKind" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "base": { "$ref": "#/$defs/EntityBaseLedger" },
        "mass": { "type": "number" },
        "health": { "type": "number" },
        "radius": { "$ref": "#/$defs/EntityRadiusConfig" },
        "explosion": { "oneOf": [{ "$ref": "#/$defs/ShotExplosion" }, { "type": "null" }] },
        "detonateOnExpiry": { "type": "boolean" },
        "maxLifespan": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "hitSound": { "oneOf": [{ "$ref": "#/$defs/SoundEntry" }, { "type": "null" }] },
        "submunitions": { "oneOf": [{ "$ref": "#/$defs/SubmunitionSpec" }, { "type": "null" }] },
        "homingTurnRate": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "homingThrust": { "oneOf": [{ "type": "number" }, { "type": "null" }] },
        "gravityForceMultiplier": { "type": "number" },
        "smokeTrail": { "oneOf": [{ "$ref": "#/$defs/SmokeTrailSpec" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "BeamShotBlueprint": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "dps", "force", "recoil", "radius", "width", "damageSphere", "gravityForceMultiplier", "hitSound"],
      "properties": {
        "type": { "const": "beam" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "dps": { "type": "number" },
        "force": { "type": "number" },
        "recoil": { "type": "number" },
        "radius": { "type": "number" },
        "width": { "type": "number" },
        "damageSphere": { "$ref": "#/$defs/ShotCollision" },
        "gravityForceMultiplier": { "type": "number" },
        "hitSound": { "oneOf": [{ "$ref": "#/$defs/SoundEntry" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "LaserShotBlueprint": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "dps", "force", "recoil", "radius", "width", "damageSphere", "duration", "gravityForceMultiplier", "hitSound"],
      "properties": {
        "type": { "const": "laser" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "dps": { "type": "number" },
        "force": { "type": "number" },
        "recoil": { "type": "number" },
        "radius": { "type": "number" },
        "width": { "type": "number" },
        "damageSphere": { "$ref": "#/$defs/ShotCollision" },
        "duration": { "type": "number" },
        "gravityForceMultiplier": { "type": "number" },
        "hitSound": { "oneOf": [{ "$ref": "#/$defs/SoundEntry" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "ForceFieldShotBlueprint": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "materialId", "angle", "transitionTime", "barrier", "hitSound"],
      "properties": {
        "type": { "const": "forceField" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "materialId": { "$ref": "#/$defs/ForceFieldMaterialId" },
        "angle": { "type": "number" },
        "transitionTime": { "type": "number" },
        "barrier": { "oneOf": [{ "$ref": "#/$defs/ForceFieldBarrierRatioConfig" }, { "type": "null" }] },
        "hitSound": { "oneOf": [{ "$ref": "#/$defs/SoundEntry" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "ShotBlueprint": {
      "oneOf": [
        { "$ref": "#/$defs/ProjectileShotBlueprint" },
        { "$ref": "#/$defs/BeamShotBlueprint" },
        { "$ref": "#/$defs/LaserShotBlueprint" },
        { "$ref": "#/$defs/ForceFieldShotBlueprint" }
      ]
    },
    "LineShotBlueprint": {
      "oneOf": [
        { "$ref": "#/$defs/BeamShotBlueprint" },
        { "$ref": "#/$defs/LaserShotBlueprint" }
      ]
    },
    "ProjectileTailShape": {
      "enum": ["cone", "cylinder", "none"]
    },
    "ForceFieldBarrierConfig": {
      "type": "object",
      "required": ["innerRange", "outerRange", "originOffsetZ", "color", "alpha", "particleAlpha"],
      "properties": {
        "innerRange": { "type": "number" },
        "outerRange": { "type": "number" },
        "originOffsetZ": { "type": "number" },
        "color": { "type": "number" },
        "alpha": { "type": "number" },
        "particleAlpha": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ProjectileShot": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "base", "mass", "health", "launchForce", "radius", "gravityForceMultiplier"],
      "properties": {
        "type": { "$ref": "#/$defs/ProjectileShotKind" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "base": { "$ref": "#/$defs/EntityBaseLedger" },
        "mass": { "type": "number" },
        "health": { "type": "number" },
        "launchForce": { "type": "number" },
        "radius": { "$ref": "#/$defs/EntityRadiusConfig" },
        "explosion": { "$ref": "#/$defs/ShotExplosion" },
        "detonateOnExpiry": { "type": "boolean" },
        "maxLifespan": { "type": "number" },
        "homingTurnRate": { "type": "number" },
        "homingThrust": { "type": "number" },
        "gravityForceMultiplier": { "type": "number" },
        "trailLength": { "type": "number" },
        "submunitions": { "$ref": "#/$defs/SubmunitionSpec" },
        "smokeTrail": { "$ref": "#/$defs/SmokeTrailSpec" }
      },
      "additionalProperties": false
    },
    "BeamShot": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "dps", "force", "recoil", "radius", "width", "damageSphere", "gravityForceMultiplier"],
      "properties": {
        "type": { "const": "beam" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "dps": { "type": "number" },
        "force": { "type": "number" },
        "recoil": { "type": "number" },
        "radius": { "type": "number" },
        "width": { "type": "number" },
        "damageSphere": { "$ref": "#/$defs/ShotCollision" },
        "gravityForceMultiplier": { "type": "number" }
      },
      "additionalProperties": false
    },
    "LaserShot": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "dps", "force", "recoil", "radius", "width", "damageSphere", "duration", "gravityForceMultiplier"],
      "properties": {
        "type": { "const": "laser" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "dps": { "type": "number" },
        "force": { "type": "number" },
        "recoil": { "type": "number" },
        "radius": { "type": "number" },
        "width": { "type": "number" },
        "damageSphere": { "$ref": "#/$defs/ShotCollision" },
        "duration": { "type": "number" },
        "gravityForceMultiplier": { "type": "number" }
      },
      "additionalProperties": false
    },
    "LineShot": {
      "oneOf": [
        { "$ref": "#/$defs/BeamShot" },
        { "$ref": "#/$defs/LaserShot" }
      ]
    },
    "ActiveProjectileShot": {
      "oneOf": [
        { "$ref": "#/$defs/ProjectileShot" },
        { "$ref": "#/$defs/BeamShot" },
        { "$ref": "#/$defs/LaserShot" }
      ]
    },
    "ForceShot": {
      "type": "object",
      "required": ["type", "shotBlueprintId", "material", "angle", "transitionTime"],
      "properties": {
        "type": { "const": "forceField" },
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "material": { "$ref": "#/$defs/ForceFieldMaterialBlueprint" },
        "angle": { "type": "number" },
        "transitionTime": { "type": "number" },
        "barrier": { "$ref": "#/$defs/ForceFieldBarrierConfig" }
      },
      "additionalProperties": false
    },
    "ShotConfig": {
      "oneOf": [
        { "$ref": "#/$defs/ProjectileShot" },
        { "$ref": "#/$defs/BeamShot" },
        { "$ref": "#/$defs/LaserShot" },
        { "$ref": "#/$defs/ForceShot" }
      ]
    },
    "ProjectileType": {
      "enum": ["projectile", "beam", "laser"]
    },
    "BeamReflectorKind": {
      "enum": ["forceField"]
    },
    "BeamPoint": {
      "type": "object",
      "required": ["x", "y", "z", "vx", "vy", "vz"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "vx": { "type": "number" },
        "vy": { "type": "number" },
        "vz": { "type": "number" },
        "reflectorEntityId": { "$ref": "#/$defs/EntityId" },
        "reflectorKind": { "$ref": "#/$defs/BeamReflectorKind" },
        "reflectorPlayerId": { "$ref": "#/$defs/PlayerId" },
        "normalX": { "type": "number" },
        "normalY": { "type": "number" },
        "normalZ": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ShotRuntimeType": {
      "enum": ["plasma", "rocket", "beam", "laser"]
    },
    "ShotRuntimeProfile": {
      "type": "object",
      "required": [
        "shotBlueprintId",
        "type",
        "projectileType",
        "isProjectile",
        "isLine",
        "isRocketLike",
        "radius",
        "deathExplosionRadius",
        "maxLifespan",
        "detonateOnExpiry",
        "hasExplosion",
        "hasSubmunitions"
      ],
      "properties": {
        "shotBlueprintId": { "$ref": "#/$defs/ShotBlueprintId" },
        "type": { "$ref": "#/$defs/ShotRuntimeType" },
        "projectileType": { "$ref": "#/$defs/ProjectileType" },
        "isProjectile": { "type": "boolean" },
        "isLine": { "type": "boolean" },
        "isRocketLike": { "type": "boolean" },
        "radius": { "$ref": "#/$defs/EntityRadiusConfig" },
        "deathExplosionRadius": { "type": "number" },
        "maxLifespan": { "type": "number" },
        "detonateOnExpiry": { "type": "boolean" },
        "hasExplosion": { "type": "boolean" },
        "hasSubmunitions": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ShotVisualProfile": {
      "type": "object",
      "required": [
        "projectileTailShape",
        "projectileTailLengthMult",
        "projectileTailRadiusMult",
        "projectileFinSizeMult",
        "burnMarkWidth",
        "lineRadius",
        "lineDamageSphereRadius",
        "lineEmissionOffset"
      ],
      "properties": {
        "projectileTailShape": { "$ref": "#/$defs/ProjectileTailShape" },
        "projectileTailLengthMult": { "type": "number" },
        "projectileTailRadiusMult": { "type": "number" },
        "projectileFinSizeMult": { "type": "number" },
        "smokeTrail": { "$ref": "#/$defs/SmokeTrailSpec" },
        "burnMarkWidth": { "type": "number" },
        "lineRadius": { "type": "number" },
        "lineDamageSphereRadius": { "type": "number" },
        "lineEmissionOffset": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ShotProfile": {
      "type": "object",
      "required": ["runtime", "visual"],
      "properties": {
        "runtime": { "$ref": "#/$defs/ShotRuntimeProfile" },
        "visual": { "$ref": "#/$defs/ShotVisualProfile" }
      },
      "additionalProperties": false
    },

    "ForceFieldPanel": {
      "type": "object",
      "required": ["offsetX", "offsetY", "angle"],
      "properties": {
        "offsetX": { "type": "number" },
        "offsetY": { "type": "number" },
        "angle": { "type": "number" }
      },
      "additionalProperties": false
    },
    "EntityRadiusConfig": {
      "type": "object",
      "required": ["visual", "hitbox", "collision"],
      "properties": {
        "visual": { "type": "number" },
        "hitbox": { "type": "number" },
        "collision": { "type": "number" }
      },
      "additionalProperties": false
    },
    "EntityDeathExplosion": {
      "type": "object",
      "required": ["radius", "force", "damage"],
      "properties": {
        "radius": { "type": "number" },
        "force": { "type": "number" },
        "damage": { "type": "number" }
      },
      "additionalProperties": false
    },
    "EntityBaseLedger": {
      "type": "object",
      "required": ["cost", "mass", "health", "deathExplosion", "radius"],
      "properties": {
        "cost": { "$ref": "#/$defs/ResourceCost" },
        "mass": { "type": "number" },
        "health": { "type": "number" },
        "deathExplosion": { "$ref": "#/$defs/EntityDeathExplosion" },
        "radius": { "$ref": "#/$defs/EntityRadiusConfig" }
      },
      "additionalProperties": false
    },
    "TurretRadiusConfig": {
      "$ref": "#/$defs/EntityRadiusConfig"
    },
    "TurretAimAngleType": {
      "enum": ["rayDirect", "rayBisectTurretAndBody", "ballisticArcLow", "ballisticArcLowOnlyUnder", "ballisticArcHigh"]
    },
    "TurretAimLockOnType": {
      "enum": ["lockOnToTurret", "lockOnToBody"]
    },
    "TurretAimStyle": {
      "type": "object",
      "required": ["angleType", "lockOnType"],
      "properties": {
        "angleType": { "$ref": "#/$defs/TurretAimAngleType" },
        "lockOnType": { "$ref": "#/$defs/TurretAimLockOnType" }
      },
      "additionalProperties": false
    },
    "TurretLockOnRelationshipExclusion": {
      "enum": ["friendly_entities", "enemy_entities"]
    },
    "TurretLockOnEntityFamilyExclusion": {
      "enum": ["buildings", "towers", "units", "turrets", "locomotions", "shots"]
    },
    "LockOnExclusionObject": {
      "type": "object",
      "required": [
        "excludeLockOnLevel0FriendsAndEnemies",
        "excludeLockOnLevel0Entities",
        "excludeLockOnLevel1Buildings",
        "excludeLockOnLevel1Towers",
        "excludeLockOnLevel1Units",
        "excludeLockOnLevel1Turrets",
        "excludeLockOnLevel1Locomotions",
        "excludeLockOnLevel1Shots"
      ],
      "properties": {
        "excludeLockOnLevel0FriendsAndEnemies": { "type": "array", "items": { "$ref": "#/$defs/TurretLockOnRelationshipExclusion" } },
        "excludeLockOnLevel0Entities": { "type": "array", "items": { "$ref": "#/$defs/TurretLockOnEntityFamilyExclusion" } },
        "excludeLockOnLevel1Buildings": { "type": "array", "items": { "type": "string" } },
        "excludeLockOnLevel1Towers": { "type": "array", "items": { "type": "string" } },
        "excludeLockOnLevel1Units": { "type": "array", "items": { "type": "string" } },
        "excludeLockOnLevel1Turrets": { "type": "array", "items": { "type": "string" } },
        "excludeLockOnLevel1Locomotions": { "type": "array", "items": { "type": "string" } },
        "excludeLockOnLevel1Shots": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "WeaponKind": {
      "enum": ["attack", "construction", "repair"]
    },
    "TurretSpreadConfig": {
      "type": "object",
      "required": ["angle", "pelletCount"],
      "properties": {
        "angle": { "type": "number" },
