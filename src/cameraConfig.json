{
  "fovDegrees": 45,
  "panMultiplier": 6.0,
  "minTerrainClearance": 80,
  "terrainCollisionMode": "none",
  "worldPaddingPercent": 20.0,
  "zoom": {
    "max": 40.0,
    "stepFraction": 0.2
  },
  "movement": {
    "scaleMode": "absolute-world-momentum",
    "absoluteZoomStepWorldUnits": 120.0,
    "absolutePanWorldUnitsPerPixel": 2.0,
    "momentum": {
      "minGain": 0.35,
      "maxGain": 3.0,
      "mouseVelocityForMaxGainPixelsPerSecond": 1800.0,
      "wheelVelocityForMaxGainDeltaPerSecond": 5000.0,
      "curve": 1.35
    }
  },
  "farReferenceDistanceFactor": 5.0,
  "battleDefaults": {
    "demoBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 5,
      "autoRotate": false,
      "autoRotateRate": 0.0
    },
    "lobbyBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 0.4,
      "autoRotate": true,
      "autoRotateRate": 0.05
    },
    "realBattle": {
      "focus": "local-commander",
      "zoom": 3.0,
      "autoRotate": false,
      "autoRotateRate": 0.0
    }
  },
  "anchor": {
    "zoomIn": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    },
    "zoomOut": {
      "screen": "screen-center",
      "terrain": "terrain-3d-water"
    },
    "rotate": {
      "screen": "screen-center",
      "terrain": "terrain-3d-water"
    },
    "pan": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    }
  }
}
