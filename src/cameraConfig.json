{
  "fovDegrees": 45,
  "smoothingTauSeconds": {
    "snap": 0.0,
    "fast": 0.05,
    "mid": 0.12,
    "slow": 0.4
  },
  "panMultiplier": 6.0,
  "worldPaddingPercent": 20.0,
  "zoom": {
    "max": 40.0,
    "maxMapCenterDistance": 50000.0,
    "stepFraction": 0.2
  },
  "constraints": {
    "zoomInLimit": "zoom-max",
    "targetBounds": "map-padding"
  },
  "movement": {
    "scaleMode": "anchor-distance-relative",
    "centerClickPan": {
      "absoluteWorldUnitsPerPixel": 5.0,
      "momentum": {
        "enabled": false,
        "minGain": 0.35,
        "maxGain": 3.0,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    },
    "zoomIn": {
      "absoluteWorldUnitsPerWheelTick": 120.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 6.0,
        "velocityForMaxGain": 5000.0,
        "curve": 1.35
      }
    },
    "zoomOut": {
      "absoluteWorldUnitsPerWheelTick": 120.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 6.0,
        "velocityForMaxGain": 5000.0,
        "curve": 1.35
      }
    },
    "altCenterClickOrbit": {
      "radiansPerPixel": 0.0025,
      "momentum": {
        "enabled": false,
        "minGain": 0.35,
        "maxGain": 1.25,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    },
    "ctrlCenterClickHeightPan": {
      "absoluteWorldUnitsPerPixel": 2.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 3.0,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    }
  },
  "farReferenceDistanceFactor": 5.0,
  "battleDefaults": {
    "demoBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 5,
      "autoRotate": false,
      "autoRotateRate": 0.0
    },
    "lobbyBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 0.4,
      "autoRotate": true,
      "autoRotateRate": 0.05
    },
    "realBattle": {
      "focus": "local-commander",
      "zoom": 3.0,
      "autoRotate": false,
      "autoRotateRate": 0.0
    }
  },
  "anchor": {
    "zoomIn": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    },
    "zoomOut": {
      "screen": "screen-center",
      "terrain": "terrain-3d-water"
    },
    "rotate": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    },
    "pan": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    }
  }
}
