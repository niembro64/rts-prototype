{
  "fovDegrees": 45,
  "panMultiplier": 6.0,
  "minTerrainClearance": 80,
  "cameraCollidesWithTerrain": true,
  "worldPaddingPercent": 20.0,
  "zoom": {
    "max": 40.0,
    "stepFraction": 0.2
  },
  "farReferenceDistanceFactor": 5.0,
  "battleDefaults": {
    "demoBattle": {
      "focus": "map-origin-map-height-agnostic",
      "zoom": 5,
      "autoRotate": false,
      "autoRotateRate": 0.0
    },
    "lobbyBattle": {
      "focus": "map-origin-map-height-agnostic",
      "zoom": 0.4,
      "autoRotate": true,
      "autoRotateRate": 0.05
    },
    "realBattle": {
      "focus": "local-commander",
      "zoom": 3.0,
      "autoRotate": false,
      "autoRotateRate": 0.0
    }
  },
  "anchor": {
    "zoomIn": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    },
    "zoomOut": {
      "screen": "screen-center",
      "terrain": "terrain-3d-water"
    },
    "rotate": {
      "screen": "screen-center",
      "terrain": "terrain-3d-water"
    },
    "pan": {
      "screen": "cursor",
      "terrain": "terrain-3d-water"
    }
  }
}
