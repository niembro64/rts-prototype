{
  "fovDegrees": 45,
  "initialPitchRadians": 0.541592653589793,
  "transitionMode": "ema",
  "transitionScope": "zoom-only",
  "smoothingTauSeconds": {
    "snap": 0.0,
    "fast": 0.02,
    "mid": 0.12,
    "slow": 0.4
  },
  "barSpringHalfLifeSeconds": {
    "snap": 0.0,
    "fast": 0.02,
    "mid": 0.18,
    "slow": 0.4
  },
  "panMultiplier": 4.0,
  "worldPaddingPercent": 0.0,
  "zoom": {
    "max": 40.0,
    "minOrbitDistance": 300.0,
    "maxOrbitDistanceMapFactor": 1.333,
    "maxMapCenterDistance": 50000.0,
    "stepFraction": 0.175,
    "distanceSampling": {
      "pointMode": "single",
      "distanceAggregation": "min",
      "ringPointCount": 8,
      "innerRadiusPixels": 100.0,
      "outerRadiusPixels": 200.0,
      "minCenterDistanceFraction": 0.1,
      "debugPointSizePixels": 10.0,
      "debugVisibleMilliseconds": 500.0,
      "debugCenterColor": "#ffb000",
      "debugInnerColor": "#ffb000",
      "debugOuterColor": "#ffb000",
      "debugSelectedColor": "#ff3030"
    }
  },
  "constraints": {
    "zoomInLimit": "zoom-max",
    "targetBounds": "map-padding"
  },
  "lostTerrainRecovery": {
    "enabled": false,
    "emaTauSeconds": 0.35
  },
  "terrainCollision": {
    "mode": "persistRaiseEye",
    "minClearance": 5.0
  },
  "movement": {
    "scaleMode": "bar-spring",
    "wheelInputMode": "bar-discrete-event",
    "cardinalYawLockEnabled": false,
    "centerClickPan": {
      "absoluteWorldUnitsPerPixel": 5.0,
      "momentum": {
        "enabled": false,
        "minGain": 0.35,
        "maxGain": 3.0,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    },
    "zoomIn": {
      "absoluteWorldUnitsPerWheelTick": 120.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 6.0,
        "velocityForMaxGain": 5000.0,
        "curve": 1.35
      }
    },
    "zoomOut": {
      "absoluteWorldUnitsPerWheelTick": 120.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 6.0,
        "velocityForMaxGain": 5000.0,
        "curve": 1.35
      }
    },
    "altCenterClickOrbit": {
      "radiansPerPixel": 0.005,
      "momentum": {
        "enabled": false,
        "minGain": 0.35,
        "maxGain": 1.25,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    },
    "ctrlCenterClickHeightPan": {
      "absoluteWorldUnitsPerPixel": 2.0,
      "momentum": {
        "enabled": true,
        "minGain": 0.35,
        "maxGain": 3.0,
        "velocityForMaxGain": 1800.0,
        "curve": 1.35
      }
    }
  },
  "farReferenceDistanceFactor": 5.0,
  "battleDefaults": {
    "demoBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 5,
      "autoRotate": false,
      "autoRotateRate": 0.0
    },
    "lobbyBattle": {
      "focus": "map-origin-use-map-height",
      "zoom": 0.4,
      "autoRotate": true,
      "autoRotateRate": 0.05
    },
    "realBattle": {
      "focus": "local-commander",
      "zoom": 3.0,
      "autoRotate": false,
      "autoRotateRate": 0.0
    }
  },
  "anchor": {
    "zoomIn": {
      "screen": "cursor",
      "terrain": "terrain-3d"
    },
    "zoomOut": {
      "screen": "screen-center",
      "terrain": "terrain-3d"
    },
    "rotate": {
      "screen": "cursor",
      "terrain": "terrain-3d"
    },
    "pan": {
      "screen": "cursor",
      "terrain": "terrain-3d"
    }
  }
}
